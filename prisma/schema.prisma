generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int       @id @default(autoincrement())
  name       String
  email      String    @unique
  password   String

  role       Role      @default(USER)

  rentals    Rental[]

  createdAt  DateTime  @default(now())
}

model Car {
  id           Int         @id @default(autoincrement())
  name         String
  plateNumber  String      @unique
  pricePerDay  Int

  status       CarStatus   @default(AVAILABLE)

  rentals      Rental[]

  createdAt    DateTime    @default(now())
}

model Rental {
  id           Int            @id @default(autoincrement())

  userId       Int
  carId        Int

  startDate    DateTime
  endDate      DateTime

  totalPrice   Int

  status       RentalStatus   @default(PENDING)

  user         User           @relation(fields: [userId], references: [id])
  car          Car            @relation(fields: [carId], references: [id])

  payment      Payment?

  createdAt    DateTime       @default(now())
}

model Payment {
  id           Int             @id @default(autoincrement())

  rentalId     Int             @unique
  rental       Rental          @relation(fields: [rentalId], references: [id])

  amount       Int

  proofUrl     String?

  status       PaymentStatus   @default(PENDING)

  createdAt    DateTime        @default(now())
}

enum Role {
  ADMIN
  USER
}

enum CarStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  INACTIVE
}

enum RentalStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REJECTED
  CANCELLED
}